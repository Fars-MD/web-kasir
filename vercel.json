{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/products/tags",
      "dest": "/api/products/tags.ts"
    },
    {
      "src": "/api/products/barcode/(.*)",
      "dest": "/api/products/barcode/$1.ts"
    },
    {
      "src": "/api/products/([a-f0-9-]+)",
      "dest": "/api/products/[id].ts"
    },
    {
      "src": "/api/products/(.*)",
      "dest": "/api/products/$1.ts"
    },
    {
      "src": "/api/categories/([^/]+)",
      "dest": "/api/categories/[id].ts"
    },
    {
      "src": "/api/categories/(.*)",
      "dest": "/api/categories/$1.ts"
    },
    {
      "src": "/api/transactions/([^/]+)",
      "dest": "/api/transactions/[id].ts"
    },
    {
      "src": "/api/transactions/(.*)",
      "dest": "/api/transactions/$1.ts"
    },
    {
      "src": "/api/dashboard/(.*)",
      "dest": "/api/dashboard/$1.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ],
  "outputDirectory": "client/dist",
  "installCommand": "npm install && cd client && npm install",
  "buildCommand": "cd client && npm run build"
}
