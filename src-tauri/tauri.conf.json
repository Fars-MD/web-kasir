{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kasirku",
  "version": "1.0.2",
  "identifier": "com.tokozhafar.kasirku",
  "build": {
    "frontendDist": "../client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "echo dev",
    "beforeBuildCommand": "echo skip"
  },
  "app": {
    "windows": [
      {
        "title": "Toko Zhafar",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/server-sidecar"],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": false
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
